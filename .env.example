# Admin panel password (change before sharing with client)
ADMIN_PASSWORD=snizzz-admin

# Superadmin (developer) — payment / commission tracker at /superadmin
# Keep this different from ADMIN_PASSWORD and do not share with the tour client.
SUPERADMIN_PASSWORD=snizzz-super

# Optional: separate signing secret for the admin cookie
# ADMIN_SECRET=replace-me
# SUPERADMIN_SECRET=replace-me

# Web Push (generate with: npx web-push generate-vapid-keys)
# Required in Vercel Production + Preview env for admin booking alerts.
# After setting keys, redeploy, then each admin device must tap
# Settings → Enable notifications (installing the app alone is not enough).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@snizzzcebu.com

# Protects /api/cron/reminders (set the same value in Vercel Cron auth if used)
# CRON_SECRET=replace-me

# Supabase — primary store for packages, bookings, settings, uploads
# Project: scjeculrqaxrpyjvjbrz (defaults in src/lib/supabase.ts if unset)
# NEXT_PUBLIC_SUPABASE_URL=https://scjeculrqaxrpyjvjbrz.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: prefer service role on the server for storage uploads
# SUPABASE_SERVICE_ROLE_KEY=

# Optional legacy fallback: Vercel Blob (used only when Supabase is unavailable)
# BLOB_READ_WRITE_TOKEN=
