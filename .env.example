# Admin panel password (change before sharing with client)
ADMIN_PASSWORD=snizzz-admin

# Optional: separate signing secret for the admin cookie
# ADMIN_SECRET=replace-me

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@snizzzcebu.com

# Protects /api/cron/reminders (set the same value in Vercel Cron auth if used)
# CRON_SECRET=replace-me
